# ---- Treckrr configuration ----
# Copy this file to `.env` and adjust the values. `.env` is gitignored.

# HTTP port the app listens on (inside the container)
APP_PORT=8080

# Public port mapped on the host (see docker-compose.yml)
HOST_PORT=8080

# Session cookie secret. MUST be changed for production.
# Generate e.g. with:  openssl rand -hex 32
SESSION_SECRET=change-me-please-generate-a-random-value

# Set to "true" when served over HTTPS so cookies get the Secure flag.
# Behind a TLS-terminating reverse proxy you can leave this false and instead
# set TRUST_PROXY=true (the Secure flag is then derived from X-Forwarded-Proto).
COOKIE_SECURE=false

# Reverse proxy (e.g. Nginx Proxy Manager, Traefik, Caddy):
# Set to "true" so the app trusts X-Forwarded-For (real client IP for the audit
# log & rate limiting) and X-Forwarded-Proto (Secure cookies over HTTPS).
# IMPORTANT: only enable when the app is ONLY reachable through your proxy,
# otherwise clients could spoof these headers.
TRUST_PROXY=false

# ---- Bootstrap admin user (created on first start) ----
# The admin manages all other users from the in-app admin area.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password

# ---- PostgreSQL (standalone container) ----
POSTGRES_USER=treckrr
POSTGRES_PASSWORD=treckrr-db-password-change-me
POSTGRES_DB=treckrr

# Connection string used by the app. Host `db` = the compose service name.
DATABASE_URL=postgres://treckrr:treckrr-db-password-change-me@db:5432/treckrr?sslmode=disable

# ---- Automatic backups (optional `backup` compose profile) ----
# Enable with:  docker compose --profile backup up -d
BACKUP_INTERVAL=86400   # seconds between dumps (86400 = daily)
BACKUP_KEEP=14          # how many dumps to retain in ./backups

# Passkeys (WebAuthn) — must match the URL browsers use to reach the app.
# Local dev defaults shown; for production set your real domain, e.g.
#   RP_ID=treckrr.example.com
#   RP_ORIGIN=https://treckrr.example.com
RP_ID=localhost
RP_ORIGIN=http://localhost:8080
